# Environment: "QA" (default, uses QA_DATABASE_URL) or "PROD" (uses DATABASE_URL)
DATABASE_ENV=QA

# Local / staging Postgres URL (used when DATABASE_ENV=QA)
QA_DATABASE_URL=postgresql://postgres:postgres@db:5432/expense_manager

# Production Postgres URL — provided by Render automatically in prod
# DATABASE_URL=

# Neon serverless Postgres — used by Alembic migrations only
# NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# --- WhatsApp Cloud API (Meta) ---
# Bearer token for the WhatsApp phone number (prod: real number, staging: test number)
WHATSAPP_TOKEN=

# Meta messages endpoint, e.g. https://graph.facebook.com/v17.0/<PHONE_NUMBER_ID>/messages
WHATSAPP_URL=

# Meta media upload endpoint, e.g. https://graph.facebook.com/v17.0/<PHONE_NUMBER_ID>/media
WHATSAPP_URL_MEDIA=

# Webhook verification token (must match what you set in Meta Developer Console)
TOKEN=

# --- SMTP (email notifications) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Storage ---
# Directory for generated PDF reports
STORAGE_PATH=/tmp/storage
